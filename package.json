{
  "name": "claudectx",
  "version": "1.0.0",
  "description": "Reduce Claude Code token usage by up to 80%. Context analyzer, auto-optimizer, live dashboard, and smart MCP tools.",
  "bin": {
    "claudectx": "./dist/index.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "llm",
    "token-optimization",
    "mcp",
    "ai-tools",
    "developer-tools",
    "cli",
    "context-window",
    "prompt-caching",
    "token-counter",
    "ai-cost"
  ],
  "author": "Horilla <dev@horilla.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Horilla/claudectx.git"
  },
  "homepage": "https://github.com/Horilla/claudectx#readme",
  "bugs": {
    "url": "https://github.com/Horilla/claudectx/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@inquirer/prompts": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sql.js": "^1.12.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.4",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "figures": "^6.0.1",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "ignore": "^5.3.1",
    "ink": "^4.4.1",
    "js-tiktoken": "^1.0.15",
    "marked": "^12.0.0",
    "ora": "^8.0.1",
    "react": "^18.2.0",
    "update-notifier": "^7.0.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "ink-testing-library": "^3.0.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
